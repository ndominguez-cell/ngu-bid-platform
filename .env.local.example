# ============================================================
# NGU Bid Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- Supabase (get from supabase.com > Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Anthropic Claude API (get from console.anthropic.com) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Secret encryption at rest ---
# Encrypts Google OAuth tokens in the database (AES-256-GCM). Any string works;
# generate a strong one, e.g.  openssl rand -base64 32
# If unset, tokens are stored unencrypted (a warning is logged). Once set, do NOT
# change or lose it — existing encrypted tokens become unrecoverable (users would
# just need to reconnect Gmail).
TOKEN_ENC_KEY=
